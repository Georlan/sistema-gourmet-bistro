# ─────────────────────────────────────────────────────────────
# KÔMA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o .env para o git (já está no .gitignore).
# ─────────────────────────────────────────────────────────────

# ── BANCO DE DADOS ─────────────────────────────────────────────
# Desenvolvimento local: usa SQLite (sem configuração)
DATABASE_URL="sqlite:///./bistro.db"

# Produção (Supabase/PostgreSQL):
# DATABASE_URL="postgresql://postgres.[PROJECT]:[SENHA]@aws-1-us-west-2.pooler.supabase.com:6543/postgres"

# ── SEGURANÇA / JWT ────────────────────────────────────────────
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="SUBSTITUA-POR-CHAVE-ALEATORIA-DE-64-CARACTERES"

# Chave de criptografia para dados sensíveis (PII) no banco
# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="SUBSTITUA-POR-CHAVE-FERNET-VALIDA"

# ── IMPRESSORA TÉRMICA ─────────────────────────────────────────
# True = simula impressão em arquivo (desenvolvimento)
# False = imprime em hardware real
SIMULATE_PRINTER="True"

# Nome da impressora no Windows (ignorado no Linux)
PRINTER_NAME="Generic / Text Only"

# Largura em caracteres (padrão 80mm = 40 colunas)
PRINTER_WIDTH="40"

# Diretório onde os jobs de impressão são salvos (fila persistente)
PRINT_JOBS_DIR="./print_jobs"

# ── IA / GEMINI ────────────────────────────────────────────────
GEMINI_API_KEY="sua-chave-gemini-api"

# ── DEPLOY ─────────────────────────────────────────────────────
# URL pública do backend (usada para callbacks e links)
APP_URL="http://192.168.1.100:8000"