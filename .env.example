# ─────────────────────────────────────────────────────────────
# KÔMA — Variáveis de Ambiente (Exemplo com Placeholders)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o .env para o git (já está no .gitignore).
# ─────────────────────────────────────────────────────────────

# ── BANCO DE DADOS ─────────────────────────────────────────────
# Desenvolvimento local: usa SQLite (sem configuração de senha)
DATABASE_URL="sqlite:///./bistro.db"

# Produção (Supabase/PostgreSQL RLS):
# DATABASE_URL="postgresql://usuario_app:SUA_SENHA@db.host.supabase.co:6543/postgres"

# ── SEGURANÇA / JWT ────────────────────────────────────────────
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="SUBSTITUA_POR_SUA_CHAVE_SECRET_KEY_ALEATORIA"

# Chave de criptografia para dados sensíveis (PII) no banco
# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="SUBSTITUA_POR_SUA_CHAVE_FERNET_ENCRYPTION_KEY"

# ── SUPERADMIN ─────────────────────────────────────────────────
SUPERADMIN_USERNAME="admin"
# Hash bcrypt gerado via get_password_hash
SUPERADMIN_PASSWORD_HASH="SUBSTITUA_PELO_HASH_BCRYPT_DA_SUA_SENHA"

# ── SENTRY (MONITORAMENTO) ─────────────────────────────────────
SENTRY_DSN=""
SENTRY_SEND_PII="False"

# ── SERVIÇOS EXTERNOS (SUPERADMIN / DEVOPS) ────────────────────
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""
RAILWAY_API_TOKEN=""
RAILWAY_PROJECT_ID=""
RAILWAY_ENVIRONMENT_ID=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
GITHUB_TOKEN=""

# ── IMPRESSORA TÉRMICA ─────────────────────────────────────────
SIMULATE_PRINTER="True"
PRINTER_NAME="Generic / Text Only"
PRINTER_WIDTH="40"
PRINT_JOBS_DIR="./print_jobs"

# ── EVOLUTION API (WHATSAPP) ───────────────────────────────────
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME=""

# ── FRONTEND CONFIG ────────────────────────────────────────────
VITE_API_URL="http://localhost:8000"
VITE_WS_URL="ws://localhost:8000"